# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://slc_user:slc_pass@localhost:5432/slc_db?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="slc_minio_access"
MINIO_SECRET_KEY="slc_minio_secret"
MINIO_BUCKET="slc-files"

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
API_PREFIX=api/v1

# ─── App Config ──────────────────────────────────────────────────────────────
RECEIPT_PREFIX=SLC
CURRENCY_SYMBOL=PKR
DATE_LOCALE=en-PK
FISCAL_YEAR_START_MONTH=4

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
